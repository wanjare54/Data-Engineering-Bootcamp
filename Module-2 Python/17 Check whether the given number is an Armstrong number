n=int(input("Please enter the any number :"))
Arm=0
x=n
L=len(str(n))
while n>0:
    Arm=(Arm)+(n%10)**L
    n=n//10
if (x==Arm):
    print("Armstrong Number")
else:
    print("Not Armstrong")